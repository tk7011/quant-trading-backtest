import pandas as pd
import numpy as np
import bisect




df = pd.read_csv("final_dataset_with_RF.csv")  # has 'Date', 'Signal', 'Returns', 'target', 'ml_prob'
#the threshhold is t=0.51
t=0.51
# Indices of confirmed buys and all sells
df['filtered_signals'] = 0
conf_buys = df.index[(df['Signal'] == 1) & (df['ml_prob'] > t)].tolist()
sells = df.index[df['Signal'] == -1].tolist()
    
for buy_idx in conf_buys:
    # Find the next sell after this buy (binary search for efficiency)
    pos = bisect.bisect_right(sells, buy_idx)
    if pos < len(sells):
        sell_idx = sells[pos]
    else:
        sell_idx = df.index[-1]   # no sell after  fill to the end
            # Mark the entire segment from buy to sell (inclusive) as 1
    df.loc[buy_idx:sell_idx, 'filtered_signals'] = 1




    #returns only when in trade
df['strategy_return'] = df['filtered_signals'] * (df['Returns'] / 100.0)


# Annualized Sharpe ratio (using only in-trade returns, but with zeros for out-of-trade periods)
if df['strategy_return'].std() != 0:
    sharpe = df['strategy_return'].mean() / df['strategy_return'].std() * np.sqrt(252)
else:
    sharpe = 0

# Equity curve and max drawdown (based on the strategy returns)
equity = (1 + df['strategy_return']).cumprod()
running_max = equity.cummax()
drawdown = (equity - running_max) / running_max
mdd = drawdown.min()

# Total return in percent (from start to end of the whole period)
total_return = (equity.iloc[-1] - 1) * 100

# Number of trades: count of entries where filtered_signals goes from 0 to 1
trade_starts = (df['filtered_signals'] == 1) & (df['filtered_signals'].shift(1).fillna(0) == 0)
n_trades = trade_starts.sum()






    


print("Best threshold:","0.51")
print("Best Sharpe: ",sharpe)
print('max_drawdown: ' ,mdd)
print('total_return: ' ,total_return)
print('n_trades: ' ,n_trades)

df.to_csv('new_csv_expecting a bug.csv')
